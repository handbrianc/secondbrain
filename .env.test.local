# Test Environment Configuration
# This file contains safe test credentials - OK to commit to version control
#
# Usage:
#   1. Start test services: docker-compose -f docker-compose.test.yml up -d
#   2. Run tests: pytest
#
# The Config class automatically loads from this file when PYTEST_CURRENT_TEST is set.

# ============================================================================
# MongoDB Test Connection
# ============================================================================
# Connection to test MongoDB instance running on port 27018
# Credentials: testuser:testpass (defined in docker-compose.test.yml)
SECONDBRAIN_MONGO_URI=mongodb://testuser:testpass@localhost:27018/secondbrain_test?authSource=admin
SECONDBRAIN_MONGO_DB=secondbrain_test
SECONDBRAIN_MONGO_COLLECTION=test_embeddings

# ============================================================================
# Ollama Test Connection
# ============================================================================
# Platform-aware Ollama endpoint selection:
# - macOS: Uses native Ollama installation (port 11434) for better performance
# - Linux/Windows: Uses Docker Ollama container (port 11435)
#
# Uncomment and set based on your platform:
SECONDBRAIN_OLLAMA_HOST=http://localhost:11434
# SECONDBRAIN_OLLAMA_HOST=http://localhost:11435  # Linux/Windows (uncomment for Linux/Windows)
#
# If not set, Config will auto-detect based on platform.

# ============================================================================
# Test Performance Overrides
# ============================================================================
# Disable expensive features for faster test execution
SECONDBRAIN_LOG_LEVEL=DEBUG
OTEL_TRACING_ENABLED=false
OTEL_METRICS_ENABLED=false
SECONDBRAIN_CIRCUIT_BREAKER_ENABLED=false
SECONDBRAIN_RATE_LIMIT_ENABLED=false

# ============================================================================
# Optional: Test-Specific Overrides
# ============================================================================
# Uncomment to override defaults for specific test scenarios
# SECONDBRAIN_CHUNK_SIZE=4096
# SECONDBRAIN_CHUNK_OVERLAP=50
# SECONDBRAIN_MAX_WORKERS=2
# SECONDBRAIN_LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
# SECONDBRAIN_LLM_MODEL=llama3.2
