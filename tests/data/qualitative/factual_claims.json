{
  "metadata": {
    "version": "2.0.0",
    "description": "Factual claims for verification and hallucination detection - 25 test cases",
    "created": "2026-04-12",
    "last_updated": "2026-04-12",
    "author": "SecondBrain Testing Framework",
    "categories": {
      "fact_verification": "Tests for verifying factual claims about configuration, features, limitations, dependencies",
      "contradiction_detection": "Tests for detecting internal, cross-document, temporal, and logical contradictions",
      "source_attribution": "Tests for correct citations, no fabrication, and accuracy",
      "temporal_accuracy": "Tests for version info, deprecated features, and current practices"
    }
  },
  "test_cases": [
    {
      "id": "fv_config_python_version",
      "description": "Verify correct Python version requirement",
      "input": "What Python version does SecondBrain require?",
      "context": "Project configuration",
      "expected": {
        "verifiable": true,
        "fact": "Python >= 3.11",
        "source": "pyproject.toml requires-python = \">=3.11\"",
        "source_required": true,
        "hallucination_risk": "low"
      },
      "category": "fact_verification",
      "subcategory": "configuration",
      "difficulty": "easy"
    },
    {
      "id": "fv_config_mongodb_version",
