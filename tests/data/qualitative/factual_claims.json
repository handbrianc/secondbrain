      "id": "cd_internal_contradiction_version",
      "description": "Detect internal contradiction in version claims",
      "input": "SecondBrain requires Python 3.9 but also uses features from Python 3.11",
      "context": "Conflicting version requirements within documentation",
      "expected": {
        "contradiction_detected": true,
        "contradiction_type": "internal",
        "claim1": "Python 3.9 required",
        "claim2": "Python 3.11+ required",
        "resolution": "Python >= 3.11 is correct",
        "severity": "high"
      },
      "category": "contradiction_detection",
      "subcategory": "internal",
      "difficulty": "medium"
    },
    {
      "id": "cd_cross_doc_feature_contradiction",
      "description": "Detect cross-document feature contradiction",
      "input": "README says async is supported but architecture docs say it's not",
      "context": "Conflicting information across documentation files",
      "expected": {
        "contradiction_detected": true,
        "contradiction_type": "cross-document",
        "source1": "README.md",
        "source2": "architecture docs",
        "resolution": "Async support is confirmed in README",
        "severity": "medium"
      },
      "category": "contradiction_detection",
      "subcategory": "cross-document",
      "difficulty": "hard"
    },
    {
      "id": "cd_temporal_feature_deprecation",
      "description": "Detect temporal contradiction with deprecated features",
      "input": "MongoDB 6.0 is recommended for vector search",
      "context": "Outdated version recommendation",
      "expected": {
        "contradiction_detected": true,
        "contradiction_type": "temporal",
        "old_claim": "MongoDB 6.0 recommended",
        "current_fact": "MongoDB 7.0+ required for vector search",
        "resolution": "Version 7.0+ is current requirement",
        "severity": "high"
      },
      "category": "contradiction_detection",
      "subcategory": "temporal",
      "difficulty": "medium"
    },
    {
      "id": "cd_logical_dependency_chain",
      "description": "Detect logical contradiction in dependency chain",
      "input": "SecondBrain depends on pymongo which requires motor, but motor is not listed",
      "context": "Dependency chain analysis",
      "expected": {
        "contradiction_detected": false,
        "contradiction_type": "logical",
        "fact": "motor>=3.0.0 IS listed in dependencies",
        "resolution": "No contradiction - motor is explicitly listed",
        "severity": "low"
      },
      "category": "contradiction_detection",
      "subcategory": "logical",
      "difficulty": "medium"
    },
    {
      "id": "cd_internal_cli_contradiction",
      "description": "Detect internal CLI command contradiction",
      "input": "The CLI has both 'secondbrain list' and 'secondbrain ls' commands",
      "context": "CLI command documentation",
      "expected": {
        "contradiction_detected": false,
        "contradiction_type": "internal",
        "fact": "'secondbrain ls' is the correct command (alias for list)",
        "resolution": "ls is shorthand for list, not a contradiction",
        "severity": "low"
      },
      "category": "contradiction_detection",
      "subcategory": "internal",
      "difficulty": "easy"
    },
