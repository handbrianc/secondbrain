# Test Environment Configuration
# This file contains safe test credentials - OK to commit to version control
#
# Usage:
#   1. Start test services: docker-compose -f docker-compose.test.yml up -d
#   2. Run tests: pytest
#
# The Config class automatically loads from this file when PYTEST_CURRENT_TEST is set.

# ============================================================================
# MongoDB Test Connection
# ============================================================================
# Connection to test MongoDB instance running on port 27018
# Credentials: testuser:testpass (defined in docker-compose.test.yml)
SECONDBRAIN_MONGO_URI=mongodb://testuser:testpass@localhost:27018/secondbrain_test?authSource=admin
SECONDBRAIN_MONGO_DB=secondbrain_test
SECONDBRAIN_MONGO_COLLECTION=embeddings_test

# ============================================================================
# Embedding Model Dimensions (Required)
# ============================================================================
# Must match the embedding model in use. MockEmbeddingGenerator used in tests
# defaults to 384 dimensions. Changing this value requires corresponding
# changes to all mock embedding vectors in test fixtures.
SECONDBRAIN_EMBEDDING_DIMENSIONS=384

# ============================================================================
# Test Performance Overrides
# ============================================================================
# Disable expensive features for faster test execution
SECONDBRAIN_LOG_LEVEL=DEBUG
OTEL_TRACING_ENABLED=false
OTEL_METRICS_ENABLED=false
SECONDBRAIN_CIRCUIT_BREAKER_ENABLED=false
SECONDBRAIN_RATE_LIMIT_ENABLED=false

# ============================================================================
# Optional: Test-Specific Overrides
# ============================================================================
# Disable streaming in tests - the streaming code path creates fresh unmocked
# VectorStorage() bypassing test patches. Set globally so all tests benefit.
SECONDBRAIN_STREAMING_ENABLED=false

# ============================================================================
# Test Threshold Overrides (for mock LLM / test data variability)
# ============================================================================
# These relaxed thresholds accommodate test environment limitations:
# - Mock LLM produces more variable answers than production LLM servers
# - Test data may not perfectly match baseline expectations
# - Lower thresholds prevent false positives while still catching major regressions
#
# Production defaults (in test files): MEAN_CONSISTENCY_THRESHOLD=0.75, EMBEDDING_STABILITY_THRESHOLD=0.80
# Test environment (here): Relaxed to 0.65 and 0.60 respectively
MEAN_CONSISTENCY_THRESHOLD=0.65
EMBEDDING_STABILITY_THRESHOLD=0.60
