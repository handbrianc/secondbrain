# Environment variables for secondbrain CLI
# Copy this to .env and configure for your environment

# MongoDB Configuration
SECONDBRAIN_MONGO_URI=mongodb://localhost:27017
SECONDBRAIN_MONGO_DB=secondbrain
SECONDBRAIN_MONGO_COLLECTION=embeddings

# Chunking Configuration
# SECONDBRAIN_CHUNK_SIZE must be > 0 and > SECONDBRAIN_CHUNK_OVERLAP
SECONDBRAIN_CHUNK_SIZE=512
SECONDBRAIN_CHUNK_OVERLAP=50

# MongoDB Docker Credentials (REQUIRED - set these before running with Docker)
# MONGODB_INITDB_ROOT_USERNAME=your_secure_username
# MONGODB_INITDB_ROOT_PASSWORD=your_secure_password

# Embedding Configuration
# SECONDBRAIN_DEFAULT_TOP_K must be > 0
SECONDBRAIN_DEFAULT_TOP_K=5
