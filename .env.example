# MongoDB credentials for Docker Compose
MONGODB_INITDB_ROOT_USERNAME=admin
MONGODB_INITDB_ROOT_PASSWORD=password

# SecondBrain configuration (optional - has defaults)
# SECONDBRAIN_MONGO_URI=mongodb://admin:password@localhost:27017
# SECONDBRAIN_CHUNK_SIZE=4096
# SECONDBRAIN_LOG_LEVEL=INFO

# ============================================================================
# Test Environment Configuration
# ============================================================================
# For test-specific settings, see .env.test template
# Copy .env.test to .env.test.local and customize as needed
#
# Test environment variables (uncomment to override):
# SECONDBRAIN_MONGO_URI=mongodb://testuser:testpass@localhost:27018/secondbrain_test?authSource=admin
# SECONDBRAIN_MONGO_DB=secondbrain_test
# SECONDBRAIN_MONGO_COLLECTION=test_embeddings
# SECONDBRAIN_OLLAMA_HOST=http://localhost:11435  # Linux/Docker
# SECONDBRAIN_OLLAMA_HOST=http://localhost:11434  # macOS (native)
# SECONDBRAIN_LOG_LEVEL=DEBUG
# OTEL_TRACING_ENABLED=false
# OTEL_METRICS_ENABLED=false
# SECONDBRAIN_CIRCUIT_BREAKER_ENABLED=false
# SECONDBRAIN_RATE_LIMIT_ENABLED=false
