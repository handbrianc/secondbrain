# MongoDB credentials for Docker Compose
MONGODB_INITDB_ROOT_USERNAME=admin
MONGODB_INITDB_ROOT_PASSWORD=password

# SecondBrain configuration (optional - has defaults)
# SECONDBRAIN_MONGO_URI=mongodb://admin:password@localhost:27017
# SECONDBRAIN_CHUNK_SIZE=4096
# SECONDBRAIN_LOG_LEVEL=INFO

# OpenTelemetry configuration
# OTEL_TRACING_ENABLED=true
# OTEL_METRICS_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer your-token
# OTEL_EXPORTER_OTLP_TIMEOUT=10
# OTEL_SERVICE_NAME=secondbrain
