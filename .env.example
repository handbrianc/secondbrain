# ============================================================================
# SecondBrain Configuration Example
# ============================================================================
# Copy this file to .env and customize for your environment.
# All settings are optional - defaults are used if not specified.
#
# Environment variable prefix: SECONDBRAIN_
# Example: SECONDBRAIN_MONGO_URI=mongodb://localhost:27017
#
# ============================================================================

# ============================================================================
# MONGODB SETTINGS
# ============================================================================
# Connection settings for MongoDB vector database

# MongoDB connection URI
# Default: mongodb://localhost:27017
# Valid: Must start with 'mongodb://' or 'mongodb+srv://'
# Example: mongodb://localhost:27017
# Example: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true
# SECONDBRAIN_MONGO_URI=mongodb://localhost:27017

# Database name
# Default: secondbrain
# Valid: Any non-empty string
# SECONDBRAIN_MONGO_DB=secondbrain

# Collection name for storing embeddings
# Default: embeddings
# Valid: Any non-empty string
# SECONDBRAIN_MONGO_COLLECTION=embeddings

# ============================================================================
# EMBEDDING MODEL SETTINGS
# ============================================================================
# Settings for the sentence-transformers embedding model

# Embedding model to use
# Default: embeddinggemma:latest
# Valid: Any model name supported by sentence-transformers service
# Example: embeddinggemma:latest
# Example: all-MiniLM-L6-v2
# Example: multi-qa-mpnet-base-dot-v1
# SECONDBRAIN_MODEL=embeddinggemma:latest

# ============================================================================
# DOCUMENT CHUNKING SETTINGS
# ============================================================================
# Settings for splitting documents into chunks for embedding

# Chunk size (number of characters/tokens per chunk)
# Default: 4096
# Valid: Positive integer (> 0)
# Must be greater than chunk_overlap
# SECONDBRAIN_CHUNK_SIZE=4096

# Chunk overlap (number of characters/tokens to overlap between chunks)
# Default: 50
# Valid: Non-negative integer (>= 0)
# Must be less than chunk_size
# SECONDBRAIN_CHUNK_OVERLAP=50

# ============================================================================
# DOCUMENT PROCESSING SETTINGS
# ============================================================================
# Settings for supported file types and document ingestion

# Supported file extensions (comma-separated, without dots)
# Default: pdf,docx,pptx,xlsx,html,htm,md,txt,asciidoc,adoc,tex,csv,
#          png,jpg,jpeg,tiff,tif,bmp,webp,wav,mp3,vtt,xml,json
# Valid: Any comma-separated list of file extensions
# Example: pdf,docx,md,txt
# Example: pdf,docx,pptx,xlsx,html,md,txt,csv,json
# SECONDBRAIN_SUPPORTED_EXTENSIONS=pdf,docx,pptx,xlsx,html,htm,md,txt,asciidoc,adoc,tex,csv,png,jpg,jpeg,tiff,tif,bmp,webp,wav,mp3,vtt,xml,json

# Maximum file size in bytes
# Default: 104857600 (100MB)
# Valid: Positive integer
# Example: 10485760 (10MB)
# Example: 52428800 (50MB)
# Example: 104857600 (100MB)
# SECONDBRAIN_MAX_FILE_SIZE_BYTES=104857600

# ============================================================================
# SEARCH SETTINGS
# ============================================================================
# Settings for semantic search functionality

# Default number of search results to return
# Default: 5
# Valid: Positive integer (> 0)
# Example: 3
# Example: 10
# Example: 20
# SECONDBRAIN_DEFAULT_TOP_K=5

# ============================================================================
# EMBEDDING GENERATION SETTINGS
# ============================================================================
# Settings for embedding vector generation and caching

# Embedding vector dimensions
# Default: 384
# Valid: Positive integer (> 0)
# Must match the dimensions of your chosen embedding model
# Example: 384 (for embeddinggemma)
# Example: 768 (for larger models)
# Example: 1024 (for very large models)
# SECONDBRAIN_EMBEDDING_DIMENSIONS=384

# Maximum number of embeddings to cache in memory
# Default: 1000
# Valid: Non-negative integer (>= 0)
# Set to 0 to disable caching
# Example: 0 (disable cache)
# Example: 500 (small cache)
# Example: 1000 (default)
# Example: 5000 (large cache)
# SECONDBRAIN_EMBEDDING_CACHE_SIZE=1000

# Batch size for embedding generation
# Default: 20
# Valid: Integer between 1 and 100
# Higher values may improve throughput but use more memory
# Example: 10 (conservative)
# Example: 20 (default)
# Example: 50 (aggressive)
# Example: 100 (maximum)
# SECONDBRAIN_EMBEDDING_BATCH_SIZE=20

# ============================================================================
# STORAGE & INDEX SETTINGS
# ============================================================================
# Settings for storage operations and index management

# Maximum retries for index ready check
# Default: 15
# Valid: Positive integer
# Number of times to retry checking if index is ready
# SECONDBRAIN_INDEX_READY_RETRY_COUNT=15

# Delay between index ready retries (seconds)
# Default: 1.0
# Valid: Positive float
# Time to wait between retry attempts
# Example: 0.5 (half second)
# Example: 1.0 (one second)
# Example: 2.0 (two seconds)
# SECONDBRAIN_INDEX_READY_RETRY_DELAY=1.0

# ============================================================================
# RATE LIMITING SETTINGS
# ============================================================================
# Settings to protect the sentence-transformers API from overload

# Maximum requests allowed in rate limit window
# Default: 10
# Valid: Positive integer
# Number of requests allowed per window period
# Example: 5 (conservative)
# Example: 10 (default)
# Example: 20 (aggressive)
# SECONDBRAIN_RATE_LIMIT_MAX_REQUESTS=10

# Rate limit window duration (seconds)
# Default: 1.0
# Valid: Positive float
# Time window for rate limit counting
# Example: 1.0 (1 second)
# Example: 5.0 (5 seconds)
# Example: 60.0 (1 minute)
# SECONDBRAIN_RATE_LIMIT_WINDOW_SECONDS=1.0

# ============================================================================
# CONNECTION VALIDATION SETTINGS
# ============================================================================
# Settings for connection caching and validation

# TTL for connection validation cache (seconds)
# Default: 60.0
# Valid: Positive float
# How long to cache connection validation results
# Example: 30.0 (30 seconds)
# Example: 60.0 (1 minute)
# Example: 300.0 (5 minutes)
# SECONDBRAIN_CONNECTION_CACHE_TTL=60.0

# ============================================================================
# MULTICORE PROCESSING SETTINGS
# ============================================================================
# Settings for parallel processing across multiple CPU cores

# Maximum number of worker processes for parallel processing
# Default: auto-detect CPU count (if not set)
# Valid: Positive integer (> 0) or unset for auto-detection
# Set to limit CPU usage or leave unset for automatic detection
# Example: 2 (limit to 2 cores)
# Example: 4 (use 4 cores)
# Example: 8 (use 8 cores)
# SECONDBRAIN_MAX_WORKERS=4

# ============================================================================
# STREAMING SETTINGS
# ============================================================================
# Settings for memory-efficient streaming processing (NEW FEATURE)

# Enable streaming processing for memory efficiency
# Default: true
# Valid: true or false
# When enabled, processes documents in streams to reduce memory usage
# SECONDBRAIN_STREAMING_ENABLED=true

# Number of chunks to process per streaming batch
# Default: 50
# Valid: Integer between 1 and 200
# Higher values may improve throughput but use more memory
# Example: 10 (conservative, low memory)
# Example: 50 (default, balanced)
# Example: 100 (aggressive, higher throughput)
# Example: 200 (maximum throughput)
# SECONDBRAIN_STREAMING_CHUNK_BATCH_SIZE=50

# ============================================================================
# COMMON USE CASES
# ============================================================================

# --- Development (local MongoDB, small documents) ---
# SECONDBRAIN_MONGO_URI=mongodb://localhost:27017
# SECONDBRAIN_CHUNK_SIZE=2048
# SECONDBRAIN_EMBEDDING_BATCH_SIZE=10
# SECONDBRAIN_MAX_WORKERS=2

# --- Production (cloud MongoDB, large documents) ---
# SECONDBRAIN_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net
# SECONDBRAIN_CHUNK_SIZE=8192
# SECONDBRAIN_EMBEDDING_BATCH_SIZE=50
# SECONDBRAIN_MAX_WORKERS=8
# SECONDBRAIN_RATE_LIMIT_MAX_REQUESTS=20

# --- Memory-constrained environment ---
# SECONDBRAIN_EMBEDDING_CACHE_SIZE=0
# SECONDBRAIN_STREAMING_ENABLED=true
# SECONDBRAIN_STREAMING_CHUNK_BATCH_SIZE=10
# SECONDBRAIN_EMBEDDING_BATCH_SIZE=10
# SECONDBRAIN_MAX_WORKERS=1

# --- High-performance server ---
# SECONDBRAIN_EMBEDDING_CACHE_SIZE=5000
# SECONDBRAIN_EMBEDDING_BATCH_SIZE=100
# SECONDBRAIN_STREAMING_CHUNK_BATCH_SIZE=200
# SECONDBRAIN_MAX_WORKERS=16
# SECONDBRAIN_RATE_LIMIT_MAX_REQUESTS=50

# ============================================================================
